{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER,PORT;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "ApiKeyAuth": {
    "Enabled": true,
    "HeaderName": "X-API-KEY",
    "Keys": [
      "change-me"
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "*"
    ]
  },
  "Upload": {
    "Root": "App_Data/uploads",
    "MaxFileBytes": 104857600
  },
  "Supabase": {
    "Url": "",
    "ServiceRoleKey": ""
  },
  "SqlGateway": {
    "Enabled": false,
    "MaxRows": 2000,
    "MaxSqlLength": 8000
  }
}
