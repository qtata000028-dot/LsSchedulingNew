# 复制为 .env.local（仅本机使用，不要提交到仓库）

# 方案 A（推荐）：Vite 代理到后端。
# 前端请求写 /api/...，由 Vite 转发到 .NET 8。
VITE_PROXY_TARGET=http://localhost:5111
VITE_PORT=3000

# 方案 B：不走代理，直接指定后端基地址（例如 cloudflared 的临时 HTTPS）。
# 设置后会跳过 Supabase 查询。
# VITE_BACKEND_BASE_URL=https://xxxxx.trycloudflare.com

# 可选：你原来的“架构密钥”（用于后端授权/校验）
VITE_API_KEY=change-me

# 可选：从 Supabase 读“当前后端公网地址”记录（比如 home-pc）
# 不填也能运行：开发阶段会默认使用同源（配合 Vite 代理）。
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
VITE_TUNNEL_NAME=home-pc
